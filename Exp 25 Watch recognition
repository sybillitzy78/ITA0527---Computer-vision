import cv2

img = cv2.imread("C:/Users/sybil/Downloads/ChatGPT Image Mar 10, 2026, 09_55_54 AM.png")

gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)

orb = cv2.ORB_create()

kp = orb.detect(gray, None)

kp, des = orb.compute(gray, kp)

result = cv2.drawKeypoints(img, kp, None, color=(0,255,0), flags=0)

cv2.imshow("Watch Recognition", result)
cv2.waitKey(0)
cv2.destroyAllWindows()
