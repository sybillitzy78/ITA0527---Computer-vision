import cv2

img = cv2.imread("C:/Users/sybil/Pictures/Screenshots/Screenshot 2026-03-04 152236.png")

gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)

threshold_value = 120
max_value = 255
ret, segmented = cv2.threshold(gray, threshold_value, max_value, cv2.THRESH_BINARY)

cv2.imshow("Original Image", img)
cv2.imshow("Segmented Image", segmented)

cv2.waitKey(0)
cv2.destroyAllWindows()
